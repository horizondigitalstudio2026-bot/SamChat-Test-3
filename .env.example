# ==============================
# SamChat — Variables d'environnement
# Copier ce fichier en ".env" et renseigner de vraies valeurs
# ==============================

# Serveur
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:4000

# Sécurité JWT (générer une chaîne aléatoire longue en production)
JWT_SECRET=change_this_super_secret_key_before_deploying
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_other_super_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Base de données SQLite
DATABASE_PATH=./server/database/samchat.db

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Uploads
MAX_UPLOAD_SIZE_MB=25
